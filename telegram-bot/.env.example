# === Bot de Telegram JVeloce - Variables de Entorno ===

# Token del bot de Telegram (obtenido de @BotFather)
TELEGRAM_BOT_TOKEN=tu_token_aqui

# API Key de Google Gemini (obtenida de https://aistudio.google.com/apikey)
GEMINI_API_KEY=tu_api_key_aqui
# Lista de API keys de Gemini separadas por comas para rotación automática y evitar límites de cuota (opcional)
GEMINI_API_KEYS=key1,key2,key3

# Tu ID numérico de Telegram (obtenido de @userinfobot). 
# Si se deja en 0, cualquier usuario podrá usar el bot.
ADMIN_TELEGRAM_ID=0

# Ruta al archivo JSON de credenciales de Firebase Service Account
# Descárgalo desde: Firebase Console > Configuración > Cuentas de servicio > Generar nueva clave privada
FIREBASE_CREDENTIALS_PATH=./firebase-service-account.json

# API Key de remove.bg (obtenida de https://www.remove.bg/)
REMOVE_BG_API_KEY=tu_api_key_de_removebg_aqui
